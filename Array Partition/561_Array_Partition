class Solution {
    public int arrayPairSum(int[] nums) {
        Arrays.sort(nums);  // Step 1: sort
        
        int sum = 0;
        
        for(int i = 0; i < nums.length; i += 2) {
            sum += nums[i]; // Step 2: take min of each pair
        }
        
        return sum;
    }
}
